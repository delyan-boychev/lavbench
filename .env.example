# ═══════════════════════════════════════════════════════════════
#  LavBench Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Run: make setup  →  auto-generates all keys and creates .env
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED (must be set) ──────────────────────────────────────
# Flask secret key — used for JWT signing and session encryption
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PostgreSQL password for the application user
POSTGRES_PASSWORD=

# ── Database ────────────────────────────────────────────────────
# Connection string for PostgreSQL.
# For local dev: localhost
# For Docker Compose: the service name 'db' is used automatically
DATABASE_URL=postgresql://lavbench_user:${POSTGRES_PASSWORD}@localhost:5432/lavbench_db

# ── Redis (message broker + cache) ──────────────────────────────
# Used by Celery for task queuing and SSE pub/sub.
# For local dev: localhost
# For Docker Compose: the service name 'redis' is used automatically
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
CELERY_RESULT_BACKEND=${CELERY_BROKER_URL}

# Redis protocol — 'redis' (plain) or 'rediss' (TLS). Set by make setup.
REDIS_PROTO=redis

# Redis password — auto-generated by make setup
REDIS_PASSWORD=

# Redis bind address — change to 127.0.0.1 for local-only access
# (default 0.0.0.0 is required for remote workers)
REDIS_BIND=0.0.0.0

# ── Redis TLS (only for rediss:// connections) ──────────────────
# Place certificate files in ./certs/ — they are mounted into
# Docker containers automatically.
# REDIS_SSL_CA_CERTS=/etc/ssl/certs/redis/redis-ca.crt
# REDIS_SSL_CERTFILE=/etc/ssl/certs/redis/redis-client.crt
# REDIS_SSL_KEYFILE=/etc/ssl/certs/redis/redis-client.key
# REDIS_SSL_CERT_REQS=required

# ── Worker Authentication ───────────────────────────────────────
# Ed25519 keypair — auto-generated by make setup.
# WORKER_PUBLIC_KEY stays on the server.
# WORKER_PRIVATE_KEY is in worker.env — copy it to workers.
SERVER_ADDRESS=localhost
MAIN_SERVER_URL=http://${SERVER_ADDRESS}:5001
WORKER_PUBLIC_KEY=

# ── Server URL configuration (set by make setup) ────────────────
# Protocol for worker callbacks: 'http' or 'https'
# SERVER_PROTOCOL=https

# ── Application ─────────────────────────────────────────────────
# Fernet key for PII encryption at rest (allows SECRET_KEY rotation)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:80

# Flask debug mode (never true in production)
FLASK_DEBUG=false

# HuggingFace dataset cache directory
HF_CACHE_DIR=./backend/hf_cache

# Celery worker concurrency (per worker node)
# CELERY_WORKER_CONCURRENCY=4

# Task scoping for Celery workers
# Set INTERNAL_ONLY_WORKER=true to run only system tasks (backups, leaderboards)
# Set EVALUATION_ONLY_WORKER=true to run only submission evaluations
# INTERNAL_ONLY_WORKER=false
# EVALUATION_ONLY_WORKER=false
