# Flask configuration (REQUIRED - no default fallback)
SECRET_KEY=replace_with_secure_random_64_chars_min

# Database configuration (PostgreSQL) (REQUIRED - no default fallback)
DATABASE_URL=postgresql://lavbench_user:lavbench_pass@localhost:5432/lavbench_db

# Celery Redis Broker configuration
# With password authentication: redis://:redis_password@localhost:6379/0
# Without password authentication (default): redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Hugging Face caching directory
HF_CACHE_DIR=./backend/hf_cache

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:80

# Flask debug mode (never true in production)
FLASK_DEBUG=false

# Worker specific settings (for GPU nodes)
# WORKER_GPU_ID=0

# Remote Worker Callback settings (For decoupled database-free workers)
# Server has only the PUBLIC key — workers have the PRIVATE key.
# Generate a new keypair with: python -c "
# from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
# import base64
# k = Ed25519PrivateKey.generate()
# print('WORKER_PUBLIC_KEY=' + base64.b64encode(k.public_key().public_bytes_raw()).decode())
# print('WORKER_PRIVATE_KEY=' + base64.b64encode(k.private_bytes_raw()).decode())
# "
MAIN_SERVER_URL=http://localhost:5001
WORKER_PUBLIC_KEY=replace_with_base64_encoded_ed25519_public_key

# Redis password (leave blank or comment out if Redis is not auth-protected)
# REDIS_PASSWORD=

# Optional: separate encryption key for Fernet (allows SECRET_KEY rotation without data loss)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Redis SSL/TLS Settings (Required for rediss:// connections)
# REDIS_SSL_CA_CERTS=/path/to/ca.crt
# REDIS_SSL_CERTFILE=/path/to/client.crt
# REDIS_SSL_KEYFILE=/path/to/client.key
# REDIS_SSL_CERT_REQS=required

# Task-scoping configurations for Celery workers
# Set INTERNAL_ONLY_WORKER=true to run only system/internal tasks (e.g. database backup, leaderboards)
# Set EVALUATION_ONLY_WORKER=true to run only submission evaluation tasks (e.g. GPU/CPU sandboxes)
# INTERNAL_ONLY_WORKER=false
# EVALUATION_ONLY_WORKER=false


