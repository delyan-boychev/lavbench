{
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "baseUrl": "src",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.*", "src/**/__tests__/**"]
}
