#!/usr/bin/env python3
import sys
import os
import subprocess
import json

LOG_PATH = "/Users/delyan-boychev/nai-webplatform/mock_docker_run.log"

def log_event(event_type, details):
    try:
        with open(LOG_PATH, "a") as f:
            f.write(json.dumps({"event": event_type, "details": details}) + "\n")
    except Exception as e:
        pass

def main():
    args = sys.argv[1:]
    if not args:
        print("Docker mock CLI. No arguments provided.")
        sys.exit(1)
        
    cmd = args[0]
    
    if cmd in ("--version", "version"):
        print("Docker version 24.0.7, build afdd53b")
        log_event("version_check", {"args": args})
        sys.exit(0)
        
    elif cmd == "info":
        print("Kernel Version: Mock Kernel")
        print("Operating System: macOS (Mocked Docker)")
        log_event("info_check", {"args": args})
        sys.exit(0)
        
    elif cmd == "build":
        # Parse build args: docker build -t image_tag context_dir
        tag = None
        context_dir = None
        for i in range(len(args)):
            if args[i] == "-t" and i + 1 < len(args):
                tag = args[i+1]
            elif args[i] == "--tag" and i + 1 < len(args):
                tag = args[i+1]
        
        if args:
            context_dir = args[-1]
            
        dockerfile_content = ""
        requirements_content = ""
        if context_dir and os.path.isdir(context_dir):
            df_path = os.path.join(context_dir, "Dockerfile")
            if os.path.exists(df_path):
                with open(df_path, "r") as f:
                    dockerfile_content = f.read()
            req_path = os.path.join(context_dir, "requirements.txt")
            if os.path.exists(req_path):
                with open(req_path, "r") as f:
                    requirements_content = f.read()
                    
        log_event("build", {
            "tag": tag,
            "context_dir": context_dir,
            "dockerfile": dockerfile_content,
            "requirements": requirements_content,
            "args": args
        })
        print(f"Successfully built mock image {tag}")
        sys.exit(0)
        
    elif cmd == "run":
        # Parse run arguments
        network = None
        pids_limit = None
        tmpfs = None
        memory = None
        volumes = []
        workdir = None
        env_vars = {}
        gpus = None
        
        i = 1
        while i < len(args):
            arg = args[i]
            if arg == "--network" and i + 1 < len(args):
                network = args[i+1]
                i += 2
            elif arg == "--pids-limit" and i + 1 < len(args):
                pids_limit = args[i+1]
                i += 2
            elif arg == "--tmpfs" and i + 1 < len(args):
                tmpfs = args[i+1]
                i += 2
            elif arg == "-m" and i + 1 < len(args):
                memory = args[i+1]
                i += 2
            elif arg == "-v" and i + 1 < len(args):
                volumes.append(args[i+1])
                i += 2
            elif arg == "-w" and i + 1 < len(args):
                workdir = args[i+1]
                i += 2
            elif arg == "-e" and i + 1 < len(args):
                val = args[i+1]
                if "=" in val:
                    k, v = val.split("=", 1)
                    env_vars[k] = v
                else:
                    env_vars[val] = os.environ.get(val, "")
                i += 2
            elif arg == "--gpus" and i + 1 < len(args):
                gpus = args[i+1]
                i += 2
            elif arg == "--rm":
                i += 1
            else:
                break
                
        remaining = args[i:]
        image_tag = remaining[0] if len(remaining) > 0 else None
        run_cmd = remaining[1:] if len(remaining) > 1 else []
        
        host_dir = None
        for vol in volumes:
            if vol.endswith(":/app"):
                host_dir = vol.split(":/app")[0]
                break
                
        log_event("run", {
            "network": network,
            "pids_limit": pids_limit,
            "tmpfs": tmpfs,
            "memory": memory,
            "volumes": volumes,
            "workdir": workdir,
            "env_vars": env_vars,
            "gpus": gpus,
            "image_tag": image_tag,
            "run_cmd": run_cmd,
            "host_dir": host_dir,
            "args": args
        })
        
        if not host_dir:
            print("Error: /app volume mapping not found in mock run command.", file=sys.stderr)
            sys.exit(1)
            
        if not run_cmd or run_cmd[0] != "python":
            print(f"Error: Unknown run command: {run_cmd}", file=sys.stderr)
            sys.exit(1)
            
        exec_file = run_cmd[1] if len(run_cmd) > 1 else "submission_runner.py"
        
        local_env = os.environ.copy()
        local_env.update(env_vars)
        
        # Execute python file locally mimicking the docker container execution
        python_exe = "/Users/delyan-boychev/nai-webplatform/venv/bin/python"
        if not os.path.exists(python_exe):
            python_exe = sys.executable
        res = subprocess.run([python_exe, exec_file], cwd=host_dir, env=local_env, capture_output=True, text=True)
        
        sys.stdout.write(res.stdout)
        sys.stderr.write(res.stderr)
        sys.exit(res.returncode)
        
    elif cmd == "ps":
        print("mock-container-123")
        log_event("ps_check", {"args": args})
        sys.exit(0)
        
    else:
        log_event("unknown_command", {"args": args})
        print(f"Warning: Mocked docker command received unknown arguments: {args}", file=sys.stderr)
        sys.exit(0)

if __name__ == "__main__":
    main()
